{
  "name": "root",
  "license": "MIT",
  "version": "0.0.0",
  "packageManager": "pnpm@11.11.0",
  "engines": {
    "node": ">=22.12.0"
  },
  "scripts": {
    "prepare": "husky",
    "commit": "commit",
    "tailwindbuddy:release:prepare": "pnpm --filter @busbud/tailwind-buddy --fail-if-no-match release:prepare",
    "tailwindbuddy:test": "pnpm --filter @busbud/tailwind-buddy --fail-if-no-match test:ci",
    "tailwindbuddy:coverage": "pnpm --filter @busbud/tailwind-buddy --fail-if-no-match test:coverage",
    "tailwindbuddy:build": "pnpm --filter @busbud/tailwind-buddy --fail-if-no-match build",
    "tailwindbuddy:typecheck": "pnpm --filter @busbud/tailwind-buddy --fail-if-no-match typecheck:tests",
    "package:publint": "publint packages/core",
    "package:attw": "attw --pack packages/core",
    "package:smoke": "node packages/core/scripts/package-smoke.mjs",
    "package:check": "pnpm tailwindbuddy:build && pnpm package:publint && pnpm package:attw && pnpm package:smoke",
    "workspaces:build": "pnpm -r --if-present build",
    "workspaces:test": "pnpm -r --if-present test",
    "generate:safelists": "pnpm --filter ui-kit --fail-if-no-match generate:safelist && pnpm --filter vuelib-tailwind4 --fail-if-no-match safelist-generation",
    "check:generated": "node scripts/check-generated.mjs",
    "lint": "eslint . --max-warnings 0",
    "format": "prettier . --write",
    "format:check": "prettier . --check",
    "docs:dev": "vitepress dev packages/documentation",
    "docs:build": "vitepress build packages/documentation",
    "docs:preview": "vitepress preview packages/documentation",
    "verify": "pnpm format:check && pnpm lint && pnpm workspaces:build && pnpm workspaces:test && pnpm tailwindbuddy:typecheck && pnpm tailwindbuddy:coverage && pnpm docs:build && pnpm package:check && pnpm check:generated"
  },
  "devDependencies": {
    "@arethetypeswrong/cli": "^0.18.5",
    "@commitlint/cli": "^21.2.1",
    "@commitlint/config-conventional": "^21.2.0",
    "@commitlint/prompt-cli": "^21.2.0",
    "@eslint/js": "^10.0.1",
    "@types/node": "^24.0.0",
    "eslint": "10.6.0",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-vue": "^10.9.2",
    "globals": "^16.4.0",
    "husky": "^9.1.7",
    "prettier": "^3.9.5",
    "publint": "^0.3.21",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.63.0",
    "vitepress": "^1.6.4"
  },
  "workspaces": [
    "packages/*"
  ]
}
