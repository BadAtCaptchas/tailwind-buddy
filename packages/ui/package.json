{
  "name": "ui-kit",
  "version": "0.0.1",
  "type": "module",
  "license": "UNLICENSED",
  "files": [
    "dist",
    "src"
  ],
  "main": "./dist/uikit.umd.cjs",
  "module": "./dist/uikit.js",
  "types": "./dist/uikit.d.ts",
  "scripts": {
    "build": "tsc && vite build",
    "build:withcss": "pnpm generate:safelist && tsc && vite build && pnpm generate:css",
    "generate:safelist": "tsx scripts/generate-safelist.ts",
    "generate:css": "tailwindcss -i ./index.css -o ./dist/style.css",
    "test": "vitest run"
  },
  "exports": {
    ".": {
      "import": "./dist/uikit.js",
      "require": "./dist/uikit.umd.cjs",
      "types": "./dist/uikit.d.ts"
    },
    "./safelist.css": "./src/generated/safelist.css",
    "./style.css": "./dist/style.css"
  },
  "dependencies": {
    "clsx": "^2.1.1",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "tailwind-merge": "^3.6.0"
  },
  "devDependencies": {
    "@microsoft/api-extractor": "^7.57.0",
    "@tailwindcss/cli": "^4.3.2",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.3",
    "@busbud/tailwind-buddy": "workspace:*",
    "tailwindcss": "^4.3.2",
    "tsx": "^4.23.0",
    "typescript": "^6.0.3",
    "vite": "^8.1.4",
    "vite-plugin-dts": "^5.0.3",
    "vitest": "^4.1.10"
  }
}
