{
  "name": "@busbud/tailwind-buddy",
  "version": "3.3.0",
  "description": "Framework-agnostic Tailwind CSS variant and slot composition with responsive and SSR-friendly class generation.",
  "type": "module",
  "license": "MIT",
  "author": "Florent Giraud",
  "keywords": [
    "tailwindcss",
    "variants",
    "slots",
    "compound-variants",
    "responsive",
    "ssr",
    "class-composition"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/busbud/tailwind-buddy.git",
    "directory": "packages/core"
  },
  "homepage": "https://busbud.github.io/tailwind-buddy",
  "bugs": {
    "url": "https://github.com/busbud/tailwind-buddy/issues"
  },
  "sideEffects": false,
  "publishConfig": {
    "access": "public"
  },
  "files": [
    "dist"
  ],
  "main": "./dist/tailwindbuddy.umd.cjs",
  "module": "./dist/tailwindbuddy.js",
  "types": "./dist/main.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/main.d.ts",
        "default": "./dist/tailwindbuddy.js"
      },
      "require": {
        "types": "./dist/main.d.cts",
        "default": "./dist/tailwindbuddy.umd.cjs"
      }
    }
  },
  "scripts": {
    "build": "tsc && vite build && node scripts/copy-cjs-types.mjs",
    "release:prepare": "pnpm prepack && changelogen --release --output ../../CHANGELOG.md",
    "prepack": "pnpm build",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:ci": "pnpm test && pnpm typecheck:tests",
    "typecheck:tests": "tsc --noEmit -p tsconfig.tests.json"
  },
  "peerDependencies": {
    "tailwindcss": "^3 || ^4"
  },
  "peerDependenciesMeta": {
    "tailwindcss": {
      "optional": true
    }
  },
  "devDependencies": {
    "@microsoft/api-extractor": "^7.57.0",
    "@vitest/coverage-v8": "^4.1.10",
    "autoprefixer": "^10.5.2",
    "changelogen": "^0.6.2",
    "postcss": "^8.5.16",
    "tailwindcss": "^4.3.2",
    "typescript": "^6.0.3",
    "vite": "^8.1.4",
    "vite-plugin-dts": "^5.0.3",
    "vitest": "^4.1.10"
  }
}
